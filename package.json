{
  "name": "quietfolio-desktop",
  "version": "0.5.0",
  "description": "Desktop home library: reading status, covers, notes, catalog search. Local SQLite.",
  "author": "Damian Ehrenburg <ehrenburgdamian@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DamianEhrenburg/quietfolio.git"
  },
  "homepage": "https://github.com/DamianEhrenburg/quietfolio#readme",
  "bugs": {
    "url": "https://github.com/DamianEhrenburg/quietfolio/issues"
  },
  "keywords": [
    "books",
    "library",
    "reading-list",
    "electron"
  ],
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild:native",
    "start": "electron .",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:search-hints": "node scripts/verify-search-hints.mjs",
    "bench:search": "npm run build && node scripts/bench-search.mjs",
    "seed:ol-index": "node scripts/seed-ol-index.mjs",
    "seed:ol-classics": "node scripts/seed-ol-classics.mjs",
    "check": "npm run lint && npm run build && npm run verify:build && npm run verify:search-hints"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "41.7.2",
    "electron-vite": "5.0.0",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.61.0",
    "vite": "^6.0.0"
  },
  "packageManager": "npm@11.16.0"
}
